---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead
			title="balesaja.com | Aplikasi Penjadwal Media Sosial & Manajemen Konten"
			description="Kelola, jadwalkan, dan analisis semua akun media sosial Anda dalam satu platform yang mudah digunakan."
		/>
		<style>
			:root {
				--page-bg: #ffffff;
				--panel: #f8fafc;
				--panel-strong: #f1f5f9;
				--line: rgba(0, 0, 0, 0.08);
				--muted: #64748b;
				--text: #0f172a;
				--primary: #6366f1; /* Indigo */
				--primary-light: #a5a6f6;
				--primary-dark: #4f46e5;
				--ink: #ffffff;
				--accent: #ec4899; /* Pink */
				--gradient-primary: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
			}

			* {
				box-sizing: border-box;
			}

			body {
				min-height: 100vh;
				background: 
					radial-gradient(circle at 16% 6%, rgba(99, 102, 241, 0.05), transparent 31rem),
					radial-gradient(circle at 86% 16%, rgba(236, 72, 153, 0.05), transparent 28rem),
					var(--page-bg);
				color: var(--text);
				font-family:
					'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				font-size: 16px;
				line-height: 1.5;
				margin: 0;
			}

			a {
				color: inherit;
				transition: color 0.2s ease;
			}

			main {
				max-width: none;
				padding: 0;
				overflow: hidden;
			}

			.site-shell {
				width: min(1180px, calc(100% - 40px));
				margin: 0 auto;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 46px;
				padding: 0 24px;
				border: 1px solid var(--line);
				border-radius: 10px;
				color: var(--text);
				font-size: 0.95rem;
				font-weight: 600;
				text-decoration: none;
				white-space: nowrap;
				transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.btn-primary {
				background: var(--gradient-primary);
				color: var(--ink);
				border-color: transparent;
				box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.4);
			}

			.btn-primary:hover {
				transform: translateY(-1px);
				box-shadow: 0 12px 30px -5px rgba(99, 102, 241, 0.5);
				opacity: 0.95;
			}

			.btn-secondary {
				background: #ffffff;
			}

			.btn-secondary:hover {
				background: var(--panel);
				border-color: var(--primary-light);
			}

			.hero {
				position: relative;
				padding: 120px 0 100px;
			}

			.hero-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				align-items: center;
				gap: 64px;
			}

			.badge {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				min-height: 32px;
				padding: 0 16px;
				border: 1px solid rgba(99, 102, 241, 0.15);
				border-radius: 999px;
				background: rgba(99, 102, 241, 0.08);
				color: var(--primary);
				font-size: 0.85rem;
				font-weight: 700;
				margin-bottom: 24px;
			}

			h1 {
				margin: 0 0 24px;
				color: var(--text);
				font-size: clamp(2.5rem, 5vw, 4rem);
				line-height: 1.1;
				letter-spacing: -0.03em;
				font-weight: 900;
			}

			h1 span {
				background: var(--gradient-primary);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}

			.lede {
				max-width: 580px;
				margin: 0;
				color: var(--muted);
				font-size: clamp(1.1rem, 1.5vw, 1.25rem);
				line-height: 1.6;
			}

			.hero-actions {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 16px;
				margin: 40px 0 32px;
			}

			.trust-row {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				color: var(--muted);
				font-size: 0.9rem;
				font-weight: 500;
			}

			.trust-pill {
				display: flex;
				align-items: center;
				gap: 6px;
				padding: 8px 16px;
				border: 1px solid var(--line);
				border-radius: 999px;
				background: #ffffff;
			}

			.trust-pill::before {
				content: "✓";
				color: var(--primary);
				font-weight: 900;
			}

			.product-preview {
				position: relative;
				padding: 12px;
				border: 1px solid var(--line);
				border-radius: 24px;
				background: #ffffff;
				box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.1);
			}

			.product-window {
				overflow: hidden;
				border: 1px solid var(--line);
				border-radius: 16px;
				background: #ffffff;
			}

			.window-bar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 12px 20px;
				border-bottom: 1px solid var(--line);
				background: var(--panel);
				color: var(--muted);
				font-size: 0.85rem;
				font-weight: 500;
			}

			.dots {
				display: flex;
				gap: 6px;
			}

			.dots span {
				width: 10px;
				height: 10px;
				border-radius: 50%;
				background: #cbd5e1;
			}

			/* Mockup Styles */
			.scheduler-mockup {
				padding: 24px;
				background: #ffffff;
				min-height: 350px;
				display: grid;
				grid-template-columns: 60px 1fr;
				gap: 20px;
			}

			.mock-sidebar {
				background: var(--panel);
				border-radius: 12px;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 16px;
				padding: 16px 0;
			}

			.mock-icon {
				width: 32px;
				height: 32px;
				border-radius: 8px;
				background: #e2e8f0;
			}

			.mock-icon.active {
				background: var(--primary);
			}

			.mock-content {
				display: flex;
				flex-direction: column;
				gap: 16px;
			}

			.mock-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.mock-title {
				font-weight: 700;
				font-size: 1.1rem;
			}

			.mock-card {
				border: 1px solid var(--line);
				border-radius: 12px;
				padding: 16px;
				display: flex;
				flex-direction: column;
				gap: 12px;
			}

			.mock-post-header {
				display: flex;
				align-items: center;
				gap: 12px;
			}

			.mock-avatar {
				width: 36px;
				height: 36px;
				border-radius: 50%;
				background: #cbd5e1;
			}

			.mock-user-info {
				display: flex;
				flex-direction: column;
			}

			.mock-username {
				font-weight: 600;
				font-size: 0.9rem;
			}

			.mock-time {
				font-size: 0.75rem;
				color: var(--muted);
			}

			.mock-post-content {
				font-size: 0.9rem;
				color: var(--text);
			}

			.mock-post-image {
				height: 120px;
				background: linear-gradient(135deg, #e0e7ff 0%, #fbcfe8 100%);
				border-radius: 8px;
			}

			.mock-post-footer {
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.8rem;
				color: var(--muted);
			}

			.mock-status {
				padding: 4px 8px;
				border-radius: 999px;
				background: rgba(16, 185, 129, 0.1);
				color: #10b981;
				font-weight: 600;
			}

			.section {
				padding: 100px 0;
				border-top: 1px solid var(--line);
			}

			.section-header {
				text-align: center;
				max-width: 800px;
				margin: 0 auto 64px;
			}

			.kicker {
				display: block;
				color: var(--primary);
				font-weight: 800;
				font-size: 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: 16px;
			}

			.section h2 {
				font-size: clamp(2.2rem, 4vw, 3.2rem);
				font-weight: 900;
				line-height: 1.1;
				margin: 0 0 20px;
				letter-spacing: -0.02em;
			}

			.feature-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 32px;
			}

			.feature-card {
				padding: 40px;
				border-radius: 20px;
				border: 1px solid var(--line);
				background: #ffffff;
				transition: all 0.3s ease;
			}

			.feature-card:hover {
				border-color: var(--primary-light);
				box-shadow: 0 20px 40px -10px rgba(99, 102, 241, 0.1);
				transform: translateY(-4px);
			}

			.icon-box {
				width: 54px;
				height: 54px;
				border-radius: 12px;
				background: rgba(99, 102, 241, 0.1);
				color: var(--primary);
				display: grid;
				place-items: center;
				font-size: 1.5rem;
				margin-bottom: 24px;
			}

			.feature-card h3 {
				font-size: 1.4rem;
				font-weight: 800;
				margin: 0 0 16px;
			}

			.feature-card p {
				color: var(--muted);
				font-size: 1rem;
				line-height: 1.6;
				margin: 0;
			}

			.workflow {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 24px;
			}

			.step {
				position: relative;
			}

			.step-num {
				font-size: 4rem;
				font-weight: 900;
				color: rgba(99, 102, 241, 0.08);
				line-height: 1;
				margin-bottom: -20px;
			}

			.step h3 {
				font-size: 1.25rem;
				font-weight: 800;
				margin: 0 0 12px;
				position: relative;
			}

			.step p {
				color: var(--muted);
				font-size: 0.95rem;
				margin: 0;
			}

			.cta-section {
				padding: 100px 0;
				background: #0f172a;
				color: #ffffff;
				border-radius: 40px;
				margin: 0 20px 40px;
				text-align: center;
				position: relative;
				overflow: hidden;
			}

			.cta-section::before {
				content: "";
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: radial-gradient(circle at 50% 50%, rgba(99, 102, 241, 0.2), transparent);
				pointer-events: none;
			}

			.cta-section h2 {
				font-size: clamp(2.5rem, 5vw, 4rem);
				font-weight: 900;
				margin-bottom: 24px;
			}

			@media (max-width: 980px) {
				.hero-grid {
					grid-template-columns: 1fr;
					text-align: center;
				}
				.lede {
					margin: 0 auto;
				}
				.hero-actions {
					justify-content: center;
				}
				.trust-row {
					justify-content: center;
				}
				.feature-grid {
					grid-template-columns: 1fr;
				}
				.workflow {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 640px) {
				.workflow {
					grid-template-columns: 1fr;
				}
				.cta-section {
					margin: 0 12px 24px;
					padding: 60px 20px;
				}
			}

			.testimonials-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 24px;
			}

			.testimonial-card {
				padding: 32px;
				border-radius: 20px;
				background: #ffffff;
				border: 1px solid var(--line);
				display: flex;
				flex-direction: column;
				gap: 20px;
			}

			.quote {
				font-size: 1.1rem;
				line-height: 1.6;
				color: var(--text);
				font-style: italic;
				margin: 0;
			}

			.author {
				display: flex;
				align-items: center;
				gap: 12px;
				margin-top: auto;
			}

			.author-info strong {
				display: block;
				font-size: 0.95rem;
				color: var(--text);
			}

			.author-info span {
				font-size: 0.85rem;
				color: var(--muted);
			}
		</style>
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
				<div class="site-shell hero-grid">
					<div>
						<span class="badge">Aplikasi Penjadwal Media Sosial</span>
						<h1>Kelola Media Sosial Anda <span>Tanpa Ribet</span></h1>
						<p class="lede">
							Satu platform untuk merencanakan, menjadwalkan, dan menganalisis semua konten media sosial Anda. Tingkatkan kehadiran digital Anda secara otomatis.
						</p>
						<div class="hero-actions">
							<a class="btn btn-primary" href="#">Mulai Gratis Sekarang</a>
							<a class="btn btn-secondary" href="#fitur">Lihat Fitur</a>
						</div>
						<div class="trust-row">
							<span class="trust-pill">Mudah Digunakan</span>
							<span class="trust-pill">Mendukung Multi-Platform</span>
							<span class="trust-pill">Analisis Real-Time</span>
						</div>
					</div>

					<div class="product-preview">
						<div class="product-window">
							<div class="window-bar">
								<div class="dots"><span></span><span></span><span></span></div>
								<span>Dashboard Penjadwal</span>
							</div>
							<div class="scheduler-mockup">
								<div class="mock-sidebar">
									<div class="mock-icon active"></div>
									<div class="mock-icon"></div>
									<div class="mock-icon"></div>
									<div class="mock-icon"></div>
								</div>
								<div class="mock-content">
									<div class="mock-header">
										<div class="mock-title">Postingan Terjadwal</div>
										<button class="btn btn-primary" style="min-height: 32px; padding: 0 12px; font-size: 0.8rem;">+ Baru</button>
									</div>
									<div class="mock-card">
										<div class="mock-post-header">
											<div class="mock-avatar"></div>
											<div class="mock-user-info">
												<div class="mock-username">Brand Anda</div>
												<div class="mock-time">Akan tayang: Besok, 10:00 WIB</div>
											</div>
										</div>
										<div class="mock-post-content">
											Siap untuk meluncurkan produk baru kami? Jangan lewatkan penawaran spesial besok! 🚀 #LaunchDay
										</div>
										<div class="mock-post-image"></div>
										<div class="mock-post-footer">
											<span>Instagram, Twitter, Facebook</span>
											<span class="mock-status">Siap</span>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="fitur" class="section">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Fitur Unggulan</span>
						<h2>Semua yang Anda Butuhkan untuk Sukses di Media Sosial</h2>
					</div>
					<div class="feature-grid">
						<div class="feature-card">
							<div class="icon-box">📅</div>
							<h3>Kalender Konten Visual</h3>
							<p>Rencanakan dan atur konten Anda dengan drag-and-drop kalender yang intuitif.</p>
						</div>
						<div class="feature-card">
							<div class="icon-box">🤖</div>
							<h3>Asisten AI Konten</h3>
							<p>Generate caption menarik dan hashtag relevan dalam hitungan detik dengan bantuan AI.</p>
						</div>
						<div class="feature-card">
							<div class="icon-box">📊</div>
							<h3>Analisis Mendalam</h3>
							<p>Pelajari performa postingan Anda dan ketahui waktu terbaik untuk mempublikasikannya.</p>
						</div>
						<div class="feature-card">
							<div class="icon-box">🔗</div>
							<h3>Multi-Platform</h3>
							<p>Hubungkan ke Instagram, TikTok, Facebook, Twitter, dan LinkedIn dalam satu tempat.</p>
						</div>
						<div class="feature-card">
							<div class="icon-box">👥</div>
							<h3>Kolaborasi Tim</h3>
							<p>Bekerja bersama tim Anda untuk menyetujui dan menjadwalkan konten tanpa hambatan.</p>
						</div>
						<div class="feature-card">
							<div class="icon-box">📥</div>
							<h3>Inbox Terpadu</h3>
							<p>Balas pesan dan komentar dari semua platform dalam satu inbox yang rapi.</p>
						</div>
					</div>
				</div>
			</section>

			<section id="cara-kerja" class="section" style="background: var(--panel);">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Proses Kami</span>
						<h2>Sederhana & Efisien</h2>
					</div>
					<div class="workflow">
						<div class="step">
							<div class="step-num">01</div>
							<h3>Hubungkan Akun</h3>
							<p>Integrasikan semua akun media sosial Anda dengan aman dalam beberapa klik.</p>
						</div>
						<div class="step">
							<div class="step-num">02</div>
							<h3>Buat & Rencanakan</h3>
							<p>Tulis konten Anda, gunakan AI untuk caption, dan atur di kalender.</p>
						</div>
						<div class="step">
							<div class="step-num">03</div>
							<h3>Jadwalkan</h3>
							<p>Tentukan waktu tayang atau biarkan sistem kami memilih waktu terbaik.</p>
						</div>
						<div class="step">
							<div class="step-num">04</div>
							<h3>Pantau Hasil</h3>
							<p>Lihat bagaimana audiens Anda merespons dan terus kembangkan jangkauan Anda.</p>
						</div>
					</div>
				</div>
			</section>



			<section id="testimonial" class="section" style="background: var(--panel);">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Testimoni</span>
						<h2>Apa Kata Mereka</h2>
					</div>
					<div class="testimonials-grid">
						<div class="testimonial-card">
							<p class="quote">"Aplikasi ini menghemat waktu saya hingga 10 jam per minggu. Menjadwalkan konten sebulan penuh kini hanya butuh beberapa jam!"</p>
							<div class="author">
								<div class="author-info">
									<strong>Andi Prasetya</strong>
									<span>Social Media Manager</span>
								</div>
							</div>
						</div>
						<div class="testimonial-card">
							<p class="quote">"Fitur AI Caption-nya sangat membantu saat saya kehabisan ide. Hasilnya natural dan sangat engaging!"</p>
							<div class="author">
								<div class="author-info">
									<strong>Budi Santoso</strong>
									<span>Content Creator</span>
								</div>
							</div>
						</div>
						<div class="testimonial-card">
							<p class="quote">"Analisisnya sangat mendalam tapi mudah dipahami. Kami bisa melihat dengan jelas konten mana yang menghasilkan penjualan."</p>
							<div class="author">
								<div class="author-info">
									<strong>Citra Lestari</strong>
									<span>Digital Marketer</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<div class="cta-section">
				<div class="site-shell">
					<h2>Siap Menguasai Media Sosial?</h2>
					<p style="font-size: 1.2rem; margin-bottom: 40px; opacity: 0.9;">Bergabunglah dengan ribuan kreator dan bisnis yang telah menghemat waktu dengan kami.</p>
					<a class="btn btn-primary" href="#" style="background: #ffffff; color: #0f172a; padding: 18px 40px; font-size: 1.1rem;">
						Mulai Sekarang - Gratis!
					</a>
				</div>
			</div>
		</main>

		<Footer />
	</body>
</html>
